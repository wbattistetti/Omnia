{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@services/*": ["../src/services/*"],
      "@utils/*": ["../src/utils/*"],
      "@types/*": ["../src/types/*"],
      "@context/*": ["../src/context/*"],
      "@hooks/*": ["../src/hooks/*"],
      "@domain/agentReviewChannel/reviewDocument": [
        "../packages/omnia-domain-core/src/review/reviewDocument.ts"
      ],
      "@domain/agentReviewChannel/reviewAudience": [
        "../packages/omnia-domain-core/src/review/reviewAudience.ts"
      ],
      "@domain/useCaseBundle/*": ["../packages/omnia-domain-core/src/usecase/bundle/*"],
      "@domain/aiAgentUseCase/*": ["../packages/omnia-domain-core/src/usecase/logic/*"],
      "@omnia/domain-core": ["../packages/omnia-domain-core/src/index.ts"],
      "@omnia/domain-core/*": ["../packages/omnia-domain-core/src/*"],
      "@omnia/domain-components": ["../packages/omnia-domain-components/src/index.ts"],
      "@omnia/domain-components/*": ["../packages/omnia-domain-components/src/*"]
    }
  },
  "include": ["src"]
}
