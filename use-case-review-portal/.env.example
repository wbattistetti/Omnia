# Opzionale — in dev/build locale il token viene letto da backend/.env (vite.config).
# Override esplicito o build CI senza backend/.env:
# VITE_AGENT_REVIEW_CHANNEL_TOKEN=
# Dopo cambio token: npm run review-portal:build
# Vuoto = proxy Vite verso Express in dev
VITE_REVIEW_API_BASE=
VITE_REVIEW_API_TARGET=http://127.0.0.1:3100
