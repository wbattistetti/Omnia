# Copia in .env.local / variabili di sistema ed adatta ai tuoi secret.
#
# ElevenLabs — catalogo voci (/v1/voices).
# Globale (default API): omit or use https://api.elevenlabs.io/v1
# Data residency EU (chiavi/workspace EU): usa la base documentata nella console ElevenLabs.
ELEVENLABS_API_BASE=https://api.eu.residency.elevenlabs.io/v1

# Opzionale (Vite): prima di ogni chiamata POST /design/ai-agent-generate mostra modale di conferma (anche una sola richiesta). Valori: 1 | true
# VITE_OMNIA_AI_AGENT_GENERATE_CONFIRM=1
# Opzionale: max richieste design LLM concorrenti dal browser (default 2). Es. 1 = serializza tutte.
# VITE_DESIGN_AI_MAX_IN_FLIGHT=2
