{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@types/*": ["../../src/types/*"],
      "@domain/useCaseBundle/*": ["../omnia-domain-core/src/usecase/bundle/*"],
      "@domain/aiAgentUseCase/*": ["../omnia-domain-core/src/usecase/logic/*"],
      "@omnia/domain-core": ["../omnia-domain-core/src/index.ts"],
      "@omnia/domain-core/*": ["../omnia-domain-core/src/*"]
    }
  },
  "include": ["src/**/*.tsx", "src/**/*.ts"]
}
