# Canvas rows are store-mirrored only (viewer-only); opt out with VITE_FLOW_VIEWER_ONLY_ROWS=false
VITE_FLOW_VIEWER_ONLY_ROWS=true

# Opzionale (solo debug UX): modale «Procedi / Annulla» prima di ogni POST /design/ai-agent-generate.
# Default: assente = nessun modale. Il limite «raffica» è sul backend (OMNIA_*_BURST_* in backend/.env).
# VITE_OMNIA_AI_AGENT_GENERATE_CONFIRM=1

