# Copia in backend/.env — caricato da server.js (dotenv)
OMNIA_WRITABLE_CONFIG=1
ELEVENLABS_API_KEY=
ELEVENLABS_API_BASE=https://api.eu.residency.elevenlabs.io/v1
# Opzionale: authtoken ngrok (stesso di dashboard → Your Authtoken) per tunnel dev senza incollarlo in UI
NGROK_AUTHTOKEN=
# Log Express: 0 = disattiva [REQUEST]/[RESPONSE] su tutte le route (resta [Omnia·BookFromAgenda·HTTP] per bookfromagenda)
# OMNIA_VERBOSE_HTTP=0
# Traccia dedicata /api/runtime/bookfromagenda* (default attiva). 0 = disattiva
# OMNIA_TRACE_BOOKFROMAGENDA=0
# Opzionale: max caratteri per body richiesta/risposta nei log (default 24576)
# OMNIA_TRACE_BOOKFROMAGENDA_BODY_MAX_CHARS=24576
#
# Ponte diagnostica debugger: Express → ApiServer (.NET) quando BookFromAgenda risponde ≥400.
# Opzionale: se vuoto, Express e ApiServer usano lo stesso file in %TEMP%/omnia-diagnostic-bridge.secret (auto all'avvio).
# In produzione imposta qui e sul processo ApiServer lo stesso valore.
OMNIA_INTERNAL_TOOL_DIAGNOSTIC_SECRET=
# Base URL dell’ApiServer che ospita /elevenlabs/* (default in codice: http://127.0.0.1:5000)
OMNIA_API_SERVER_URL=http://127.0.0.1:5000
# Log ponte Express→ApiServer: 1 (default) o vuoto = stampa NOTIFY_* / SKIP; 0 = silenzioso (solo effetti)
# OMNIA_DIAGNOSTIC_BRIDGE_LOG=0
