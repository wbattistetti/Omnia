{
  "openapi": "3.0.3",
  "info": {
    "title": "Omnia mock — slot appuntamenti",
    "version": "1.0.0",
    "description": "API di test: genera slot casuali. Usare in Omnia come qualsiasi backend con OpenAPI (URL dello spec o della chiamata)."
  },
  "servers": [
    {
      "url": "http://localhost:3110",
      "description": "Default locale (PORT env per cambiare)"
    }
  ],
  "tags": [{ "name": "Appointments", "description": "Disponibilità" }],
  "paths": {
    "/slots": {
      "get": {
        "operationId": "listAppointmentSlots",
        "tags": ["Appointments"],
        "summary": "Elenco slot disponibili",
        "description": "Genera slot per un intervallo di giorni: per ogni giorno nella finestra [startDate, startDate+days) crea fino a slotsPerDay slot con orari casuali tra startHour e endHour (endHour escluso). Nessun default server-side: tutti i parametri query sono obbligatori.",
        "parameters": [
          {
            "name": "startDate",
            "in": "query",
            "required": true,
            "description": "Data di partenza della finestra: data ISO YYYY-MM-DD, oppure le costanti letterali \"Now\" (oggi UTC) o \"Tomorrow\" (domani UTC).",
            "schema": { "type": "string" }
          },
          {
            "name": "days",
            "in": "query",
            "required": true,
            "description": "Numero di giorni da generare/cercare (intero ≥ 1).",
            "schema": { "type": "integer", "minimum": 1, "maximum": 60 }
          },
          {
            "name": "slotsPerDay",
            "in": "query",
            "required": true,
            "description": "Slot per giorno (massimo slot generati in ogni giorno della finestra).",
            "schema": { "type": "integer", "minimum": 1, "maximum": 50 }
          },
          {
            "name": "startHour",
            "in": "query",
            "required": true,
            "description": "Ora di inizio della finestra giornaliera per sorteggiare gli slot (0–23).",
            "schema": { "type": "integer", "minimum": 0, "maximum": 23 }
          },
          {
            "name": "endHour",
            "in": "query",
            "required": true,
            "description": "Ora esclusiva di fine fascia giornaliera (1–24); nessuna ora sorteggiata ≥ endHour.",
            "schema": { "type": "integer", "minimum": 1, "maximum": 24 }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista slot",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["slots"],
                  "properties": {
                    "slots": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AppointmentSlot" }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Parametri non validi",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AppointmentSlot": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "start": {
            "type": "string",
            "format": "date-time",
            "description": "Inizio slot (ISO 8601)"
          },
          "end": {
            "type": "string",
            "format": "date-time",
            "description": "Fine slot (ISO 8601), 30 min dopo start"
          }
        }
      }
    }
  }
}
